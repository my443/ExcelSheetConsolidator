<Window x:Class="ExcelConsolidator.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ExcelConsolidator"
        mc:Ignorable="d"
        Title="Excel Sheet Consolidator" Height="500" Width="800" MaxHeight="500" MaxWidth="800">
    <Grid>


        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>            
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0" Background="#F3F3F3" LastChildFill="False">
            <Label Content="Excel Sheet Consolidator" 
                   DockPanel.Dock="Left" 
                   VerticalAlignment="Center" 
                   Margin="10,0" 
                   FontWeight="Bold"/>

            <Button Content="About" 
                    DockPanel.Dock="Right" 
                    VerticalAlignment="Center" 
                    Padding="10,2" 
                    Margin="10,0"
                    Click="ShowAbout_Click"/>
        </DockPanel>
        <StackPanel Grid.Row="1">
            <TextBlock Margin="20 20 0 0">
                <Bold>Excel Sheet Consolidator</Bold> will combine data from a directory of similar Excel files into one spreadsheet.<LineBreak/> 
                Select the source directory, template file, and output file below.
            </TextBlock>
        </StackPanel>

        <Grid Grid.Row="2" Margin="20">
            <StackPanel>
                <StackPanel Margin="0,0">
                    <StackPanel Orientation="Horizontal">
                        <Button Content="Select Source Folder" Click="SelectSourceFolder_Click" Width="200" Height="40" HorizontalAlignment="Left"/>
                        <TextBlock Margin="10">This will be a directory of Excel files that you want to extract data from.</TextBlock>
                    </StackPanel>
                    <Label Content="{Binding FolderPathDisplay}" Background="#FFDEDEDE" Foreground="Black"  HorizontalAlignment="Stretch" Margin="0,5,0,0"/>
                </StackPanel>

                <StackPanel Margin="0,10">
                    <StackPanel Orientation="Horizontal">
                        <Button Content="Select Template File" Click="SelectTemplateFile_Click" Width="200" Height="40" HorizontalAlignment="Left"/>
                        <TextBlock Margin="10">This will be the file where you have defined which cells will be extracted.</TextBlock>
                    </StackPanel>
                    <Label Content="{Binding TemplateFilePath}" Background="#FFDEDEDE" Foreground="Black"  HorizontalAlignment="Stretch" Margin="0,5,0,0"/>
                </StackPanel>

                <StackPanel Margin="0,10">
                    <StackPanel Orientation="Horizontal">
                        <Button Content="Select Output File" Click="SelectOutputFile_Click" Width="200" Height="40" HorizontalAlignment="Left"/>
                        <TextBlock Margin="10">This will be the file that is saved with all of the extracted data.</TextBlock>
                    </StackPanel>
                    <Label Content="{Binding OutputFilePath}" Background="#FFDEDEDE" Foreground="Black"  HorizontalAlignment="Stretch" Margin="0,5,0,0"/>
                </StackPanel>

                <Button Content="Consolidate Workbooks" 
                    HorizontalAlignment="Right" 
                    Margin="0,5,0,0" 
                    Height="49" Width="232" 
                    Click="Button_Click" 
                    IsEnabled="{Binding SubmitIsEnabled}"/>
            </StackPanel>
        </Grid>
        <StatusBar Grid.Row="3">
            <Label Content="{Binding StatusMessage}"></Label>
        </StatusBar>
    </Grid>
</Window>
