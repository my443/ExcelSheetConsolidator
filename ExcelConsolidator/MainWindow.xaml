<Window x:Class="ExcelConsolidator.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ExcelConsolidator"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid>
        <Button Content="Consolidate Workbooks" HorizontalAlignment="Left" Margin="520,333,0,0" VerticalAlignment="Top" Height="49" Width="232" Click="Button_Click" IsEnabled="{Binding SubmitIsEnabled}"/>
        <Label Content="{Binding FolderPathDisplay}" HorizontalAlignment="Left" Margin="81,108,0,0" VerticalAlignment="Top"/>
        <Label Content="{Binding TemplateFilePath}" HorizontalAlignment="Left" Margin="81,207,0,0" VerticalAlignment="Top"/>
        <Label Content="{Binding OutputFilePath}" HorizontalAlignment="Left" Margin="76,268,0,0" VerticalAlignment="Top"/>
        <Button Content="Select Source Folder" HorizontalAlignment="Left" Margin="86,83,0,0" VerticalAlignment="Top" Click="SelectSourceFolder_Click"/>

    </Grid>
</Window>
