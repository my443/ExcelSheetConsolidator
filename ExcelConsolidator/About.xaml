<Window x:Class="ExcelConsolidator.About"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ExcelConsolidator"
        mc:Ignorable="d"
        Title="About" Height="220" Width="400">
    <Grid>

        <StackPanel Margin="20">
            <TextBlock FontSize="24" HorizontalAlignment="Center" TextAlignment="Center" Width="373">Excel Sheet Consolidator</TextBlock>
            <TextBlock FontSize="12" HorizontalAlignment="Center" TextAlignment="Center" Width="373">
            Written by: <Bold>John van Dijk</Bold> (2026)<LineBreak/>
                License: M.I.T.
            </TextBlock>

            <Button Content="Close" Width="80" Margin="0,20,0,0" Click="Close_Click" HorizontalAlignment="Right"/>
        </StackPanel>

    </Grid>
</Window>
