<Window x:Class="ExcelConsolidator.About"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ExcelConsolidator"
        mc:Ignorable="d"
        Title="About" Height="450" Width="800">
    <Grid>

        <StackPanel Margin="20">
            <TextBlock>Excel Sheet Consolidator<LineBreak/>
            Written by: <Bold>John van Dijk</Bold> (2026)<LineBreak/>
                License: MTI
            </TextBlock>
            <TextBlock TextWrapping="Wrap" FontSize="14">
            For documentation visit 
            <Hyperlink NavigateUri="https://github.com/my443/ExcelSheetConsolidator/Documentation" RequestNavigate="Hyperlink_RequestNavigate">
                https://github.com/my443/ExcelSheetConsolidator/Documentation
            </Hyperlink>.
            </TextBlock>
            <Button Content="Close" Width="80" Margin="0,20,0,0" Click="Close_Click" HorizontalAlignment="Right"/>
        </StackPanel>

    </Grid>
</Window>
